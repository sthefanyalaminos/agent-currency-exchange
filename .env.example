# ==============================================
# Agente de IA - Cotação de Moedas (n8n)
# Copie este arquivo para ".env" e preencha com seus valores reais.
# Não commite o arquivo ".env" com valores reais no GitHub.
# ==============================================

# --- Google Gemini (Google AI API) ---
# Usado no node "Google Gemini Chat Model" (credencial: Google Gemini(PaLM) Api account)
# Gere sua chave em: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Redis (memória de conversa do agente) ---
# Usado no node "Redis Chat Memory" (credencial: Redis account)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DATABASE=0

# --- AwesomeAPI (cotação de moedas) ---
# Usado no node "HTTP Request" (query param "token" na URL)
# Opcional: sem token, as respostas ficam em cache de 1 minuto.
# Gere um token gratuito em: https://awesomeapi.com.br
AWESOMEAPI_TOKEN=your_awesomeapi_token_here